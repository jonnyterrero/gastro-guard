# Supabase backend / CLI — copy to .env in this folder if you use local tooling.
# See also frontend/.env.example for the Next.js app (browser + API routes).

# Project URL and keys (Supabase → Project Settings → API)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role (server-only; never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres URL for migrations / local supabase db
# DATABASE_URL=
