# Copy to .env.local and fill in values from Supabase → Project Settings → API.
# Never commit .env.local (real secrets).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: required for /api/entries, /api/profile, /api/analytics.
# Use the service_role key (secret). These routes call resolve_api_key() and bypass RLS as needed.
SUPABASE_SERVICE_ROLE_KEY=
